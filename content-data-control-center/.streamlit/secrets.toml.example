# Copy the contents of this file into the Streamlit Cloud secrets dashboard.
# Go to: your app → Settings → Secrets → paste everything below, filled in.

OPENROUTER_API_KEY = "your_openrouter_api_key_here"

# The long ID from your Google Sheet URL
GOOGLE_SHEET_ID = "your_google_sheet_id_here"

# The folder ID from your Google Drive review docs folder URL
GOOGLE_DRIVE_FOLDER_ID = "your_drive_folder_id_here"

# Paste the ENTIRE contents of your Google service account credentials JSON here,
# as a single-line string.
GOOGLE_CREDENTIALS_JSON = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'
